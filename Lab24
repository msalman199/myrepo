Task 2: Creating Interactive Line Charts
Subtask 2.1: Basic Line Chart Setup
Create your first interactive line chart with sample data:

import plotly.graph_objects as go
import plotly.express as px
import pandas as pd
import numpy as np

# Create sample data for a line chart
months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 
          'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec']
sales_2022 = [15000, 18000, 22000, 25000, 28000, 32000, 
              35000, 38000, 33000, 29000, 26000, 31000]
sales_2023 = [17000, 20000, 24000, 27000, 31000, 35000, 
              38000, 41000, 36000, 32000, 29000, 34000]

# Create the line chart
fig = go.Figure()

# Add first line
fig.add_trace(go.Scatter(
    x=months,
    y=sales_2022,
    mode='lines+markers',
    name='Sales 2022',
    line=dict(color='blue', width=3),
    marker=dict(size=8)
))

# Add second line
fig.add_trace(go.Scatter(
    x=months,
    y=sales_2023,
    mode='lines+markers',
    name='Sales 2023',
    line=dict(color='red', width=3),
    marker=dict(size=8)
))

# Update layout
fig.update_layout(
    title='Monthly Sales Comparison',
    xaxis_title='Month',
    yaxis_title='Sales ($)',
    hovermode='x unified'
)

# Display the plot
fig.show()
